{
  "name": "@codehaus-au/takcli",
  "version": "0.4.1",
  "description": "Operator CLI for TAK workflows.",
  "type": "module",
  "bin": {
    "takcli": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "scripts/install.sh"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf coverage dist *.tgz",
    "lint": "eslint .",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "rimraf": "^6.0.1",
    "selfsigned": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^4.0.0"
  }
}
